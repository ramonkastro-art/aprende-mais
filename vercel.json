{
  "rewrites": [
    {
      "source": "/api/generate",
      "destination": "/api/generate"
    },
    {
      "source": "/api/painel",
      "destination": "/api/painel"
    },
    {
      "source": "/api/avaliacao-salvar",
      "destination": "/api/avaliacao-salvar"
    },
    {
      "source": "/api/avaliacao-buscar",
      "destination": "/api/avaliacao-buscar"
    },
    {
      "source": "/painel",
      "destination": "/api/painel-view"
    },
    {
      "source": "/avaliacao",
      "destination": "/api/avaliacao-view"
    },
    {
      "source": "/avaliacao.html",
      "destination": "/api/avaliacao-view"
    },
    {
      "source": "/corrigir/:id",
      "destination": "/api/corrigir-view?id=$id"
    },
    {
      "source": "/manifest.json",
      "destination": "/public/manifest.json"
    },
    {
      "source": "/sw.js",
      "destination": "/public/sw.js"
    },
    {
      "source": "/icon-192.png",
      "destination": "/public/icon-192.png"
    },
    {
      "source": "/icon-512.png",
      "destination": "/public/icon-512.png"
    },
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}